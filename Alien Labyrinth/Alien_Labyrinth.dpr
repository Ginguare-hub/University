Procedure FromElevatorOneToExit();
Begin
    Write(#13#10'Успешно спустившись на первый этаж, идите в левый коридор.'#13#10 +
          '-> Поверните налево два раза.'#13#10 +
          '-> Пройдите ещё немного вперёд и ступайте в шлюз выхода, чтобы наконец покинуть это странное место.'#13#10
          );
End;

Procedure FromElevatorTwoToElevatorOne();
Var
    Number: Integer;
Begin
    Write(#13#10'После спуска на второй этаж вы видите развилку. Куда пойдёте?'#13#10);
    Write('1) Налево'#13#10 +
          '2) Направо'#13#10);

    Number := ReadAndVerify(1, 2, '> ');
    If Number = 1 Then
    Begin
        Write(#13#10'Немного подумав, вы решили смело шагнуть налево и пойти по этому пути. Посмотрим, куда вас это приведёт:'#13#10);
        Write('-> Поверните налево.'#13#10 +
              '-> Направо.'#13#10 +
              '-> Снова направо.'#13#10 +
              '-> Пройдите примерно 50 метров вперёд.'#13#10 +
              '-> Комната, в которой вы очутились, прилегает к помещению с большим компьютером. Краем уха вы слышите колкое замечание в сторону вашего веса. Интересно, "то", что запечатлено в этом устройстве, только по отношению к вам такое позволяет, или оно просто не любит всё живое? Однако решено продолжить путь.'#13#10 +
              '-> Идите далее по коридору, пока не упрётесь в стену.'#13#10 +
              '-> Поверните направо на 90 градусов и идите вперёд.'#13#10 +
              '-> Перед вами такой же лифт, как и тот, из которого вы недавно вышли. Цифры указывают, что он связан с первым этажом. Спускайтесь.'#13#10);
    End
    Else
    Begin
        Write(#13#10'Без лишних раздумий, идя по правой стене, можно точно найти, как же отсюда выбраться:'#13#10);
        Write('-> Поверните направо.'#13#10 +
              '-> Два раза налево.'#13#10 +
              '-> Пройдя немного вперёд, единственным поворотом снова оказывается поворот налево. Может, надо было изначально идти налево?'#13#10 +
              '-> Следующий поворот направо.'#13#10 +
              '-> Развилка. Слева видно комнату с какими-то своеобразными стендами, вы решаете заглянуть. Первое, что бросается в глаза — книга. На ней большими и строгими буквами написано слово "ELYSIUM". Похоже, эта книга была ценным артефактом для пришельцев. Однако нельзя отвлекаться, вы снова ищете путь наружу.'#13#10 +
              '-> Идите направо 30 метров.'#13#10 +
              '-> Поверните направо на 90 градусов и идите вперёд до упора.'#13#10 +
              '-> Снова поверните налево.'#13#10 +
              '-> Идите направо, пока не увидите уже знакомый вам отсек лифта. Цифры указывают, что он связан с первым этажом. Спускайтесь.'#13#10);
    End;

End;

