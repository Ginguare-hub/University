          '-> После, повернув направо два раза, вы увидите шлюз выхода. Ступайте туда, чтобы выйти отсюда.'#13#10
          );
End;

Procedure FromLabToExit();
Begin
    Write(#13#10#13#10'Итак, вы находитесь в межпланетной лаборатории. Для того чтобы выбраться отсюда, нужно сделать такие шаги:'#13#10);
    Write('-> При выходе из комнаты идите налево и вперёд.'#13#10 +
          '-> Снова налево.'#13#10 +
          '-> Направо.'#13#10 +
          '-> Вы увидите лифт. В него НЕ нужно идти, просто поверните снова направо и идите по коридору.'#13#10 +
          '-> На следующем повороте налево будет видно шлюз выхода. Смело идите туда, чтобы выйти.');
End;

Procedure FromGlad_aiToExit();
Begin
    Write(#13#10#13#10'Вы обнаруживаете себя в отсеке с большим компьютером. Подойдя к нему, на вас обрушивается неизвестный женский голос, который начал что-то говорить про эксперименты, тайную подземную лабораторию и какие-то "Модули подавления интеллекта", которые сейчас летают где-то в космосе. ' +
          'Голос не внушает большого доверия и звучит довольно высокомерно, поэтому вы решаете сосредоточиться на поиске выхода. Вот подробная инструкция:'#13#10 +
          '-> При выходе из отсека держитесь правее.'#13#10 +
          '-> После поворота направо идите вперёд до комнаты с каким-то инопланетным хламом. Тут ничего полезного найти не получится.'#13#10 +
          '-> Снова поверните направо и идите вперёд.'#13#10 +
          '-> Смело заходите в отсек перед вами. По характерным стрелкам и надписи "1-2" вы понимаете — перед вами лифт на первый этаж.'#13#10
          );
    FromElevatorOneToExit();
End;

Procedure FromRelicToExit();
Begin
    Write(#13#10#13#10'Вокруг вас находится большое количество различных странных вещей. Видимо, пришельцам они довольно ценны, так как украшены чудно переливающимися сплавами и камнями неизвестного происхождения. Для того чтобы выйти, следуйте последовательности шагов:'#13#10 +
          '-> После выхода из комнаты идите налево.'#13#10 +
          '-> По правую сторону вы увидите коридор, просто продолжайте двигаться прямо.'#13#10 +
          '-> После того как упрётесь в стену, два раза поверните налево.'#13#10 +
          '-> Поверните направо и идите вперёд, пока не увидите небольшую комнатку.'#13#10 +
          '-> Смело заходите в отсек перед вами. По характерным стрелкам и надписи "1-2" вы понимаете — перед вами лифт на первый этаж.'#13#10
          );
    FromElevatorOneToExit();
End;

Procedure FromControlHubToExit();
Begin
    Write(#13#10#13#10'Очень тихо. Это первое, что вы замечаете за время, проведённое в этом отсеке. Отсек довольно большой, и тут много разнообразных механизмов. По виду можно сделать вывод, что вы в центре управления всем кораблём. Следуйте алгоритму, чтобы выбраться:'#13#10 +
          '-> Просто при выходе поверните направо и зайдите в отсек. По характерным стрелкам и надписи "2-3" вы понимаете — перед вами лифт, который соединяет второй и третий этажи.'#13#10
          );
    FromElevatorTwoToElevatorOne();
    FromElevatorOneToExit();
End;

Procedure FromDiscoToExit();
Begin
    Write(#13#10#13#10'Вся комната — это большой отсек для танцев и караоке, и от него веет безумным стилем диско! Вы впечатлены вкусом пришельцев и даёте себе волю немного отдохнуть. В конце концов, устав от музыки, вы решаете — нужно искать выход:'#13#10);
    Write('-> Идите направо 60 метров.'#13#10 +
          '-> Поверните направо.'#13#10 +
          '-> Налево 15 метров.'#13#10 +
          '-> Направо и после снова направо.'#13#10 +
          '-> Налево.'#13#10 +
          '-> По правой стороне коридора растут дивные красные растения. Они выглядят непривычно, и вы не решаетесь до них дотронуться.'#13#10 +
          '-> Следующий поворот налево.'#13#10 +
          '-> Направо и снова налево.'#13#10 +
          '-> Тут небольшая развилка. Идите в любую сторону, в конце они смыкаются в нужный нам тоннель.'#13#10 +
          '-> Направо 70 метров.'#13#10 +
          '-> Направо и снова направо.'#13#10 +
          '-> По левой стороне будет видна кабина. По стрелкам, указывающим вверх и вниз, можно понять, что это аналог лифта. Цифры же указывают, что он соединяет второй и третий этаж — то, что нам нужно. Заходим.'#13#10
          );
    FromElevatorTwoToElevatorOne;
    FromElevatorOneToExit;
End;

Procedure WriteInstructionsToExit(InitialFloor: Floors);
Var
    ActualRoom: Rooms;
Begin

    Case InitialFloor of
        flFirst:
            ActualRoom := SelectFirstFloorRoom;
        flSecond:
            ActualRoom := SelectSecondFloorRoom;
        flThird:
            ActualRoom := SelectThirdFloorRoom;
    End;

    Case ActualRoom of
        rXeno:
            FromXenoToExit();
        rLab:
            FromLabToExit();
        rGlad_ai:
            FromGlad_aiToExit();
        rRelic:
            FromRelicToExit();
        rControlHub:
            FromControlHubToExit();
        rDisco:
            FromDiscoToExit();
    End;

End;

Procedure WriteStory();
Begin
    WriteLn(#13#10'Ничего не предвещало беды, как вдруг Вас прямо из офиса украли ''инопланетяне'' и поместили в свой корабль, который разбился неподалёку от Вашего городка. Похоже, это были не простые пришельцы, а человекоподобные существа, но явно более развитые, и у них явно был опыт космических путешествий. Вам приготовили отдельный отсек, и какое-то время содержали, пока в один день что-то не поменялось. Вы проснулись в полном непонимании того, сколько прошло времени, всё вокруг поменялось, и казалось каким-то странным и неестественным, все двери были открыты и в панике вы начали бегать по всему корпусу корабля в поисках выхода отсюда. Так как время шло, а выход найден не был, пришлось остановиться и оглядеться.'#13#10)
End;

Var
    ExactFloor: Floors;

Begin
    WriteStory();
    ExactFloor := FindPlayerFloor();
    ShowFloorMap(ExactFloor);
    WriteInstructionsToExit(ExactFloor);
    WriteLn(#13#10'Вам удалось покинуть корабль!');
    ReadLn;
End.
