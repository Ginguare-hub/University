    WriteLn('В какой комнате вы находитесь?');
    Write('1)  GLaD-AI'#13#10 +
          '2)  RELIC'#13#10);

    RoomNumber := ReadAndVerify(1, 2, '> ');

    If RoomNumber = 1 Then
        Room := rGlad_ai
    Else
        Room := rRelic;

    SelectSecondFloorRoom := Room;
End;

Function SelectThirdFloorRoom(): Rooms;
Var
    Room: Rooms;
    RoomNumber: Integer;
Begin
    RoomNumber := 0;

    WriteLn('В какой комнате вы находитесь?');
    Write('1)  CONTROL HUB'#13#10 +
          '2)  THE LARGEST SHIP COMPARTMENT IN THE WHOLE UNIVERSE DEDICATED EXCLUSIVELY TO PLAY DISCO'#13#10);

    RoomNumber := ReadAndVerify(1, 2, '> ');

    If RoomNumber = 1 Then
        Room := rControlHub
    Else
        Room := rDisco;

    SelectThirdFloorRoom := Room;
End;

