Function ReadAndVerify(Const MIN_NUMBER, MAX_NUMBER: Integer; MyString: String): Integer;

Var
    IsCorrect: Boolean;
    Number: Integer;

Begin
    IsCorrect := True;
    Number := 0;

    Repeat
        Write(MyString);
        IsCorrect := True;

        Try
            ReadLn(Number);
        Except
            WriteLn('Неправильный ввод, повторите попытку.');
            IsCorrect := False;
        End;

        If IsCorrect And ((Number < MIN_NUMBER) Or (Number > MAX_NUMBER)) Then
        Begin
            WriteLn('Введённое число должно попадать в диапазон [', MIN_NUMBER, ',', MAX_NUMBER, '].');
            IsCorrect := False;
        End;

    Until IsCorrect;

    ReadAndVerify := Number;
End;

Function FindPlayerFloor(): Floors;
Var
    ExactFloor: Floors;
    ReadedNumber: Integer;
Begin
    ExactFloor := flFirst;

    WriteLn('Какого цвета стены вокруг вы наблюдаете?');
    Write(  '1)  Зелёный'#13#10 +
            '2)  Фиолетовый'#13#10 +
            '3)  Белый'#13#10);

    ReadedNumber := ReadAndVerify(1, 3, '> ');

    If ReadedNumber = 1 Then
    Begin
        ExactFloor := flSecond;
        Write(#13#10'Вы находитесь на Втором этаже'#13#10);
    End
    Else
        If ReadedNumber = 2 Then
        Begin
            ExactFloor := flThird;
            Write(#13#10'Вы находитесь на Третьем этаже'#13#10);
        End
        Else
            If ReadedNumber = 3 Then
            Begin
                ExactFloor := flFirst;
                Write(#13#10'Вы находитесь на Первом этаже'#13#10);
            End;

    FindPlayerFloor := ExactFloor;
End;

Procedure ShowFloorMap(ExactFloor: Floors);
Begin
    Case ExactFloor of
        flFirst:
            ShowFirstFloorMap;
        flSecond:
            ShowSecondFloorMap;
        flThird:
            ShowThirdFloorMap;
    End;
End;

Function SelectFirstFloorRoom(): Rooms;
Var
    Room: Rooms;
    RoomNumber: Integer;
Begin
    RoomNumber := 0;

    WriteLn('В какой комнате вы находитесь?');
    Write('1)  XEN-O'#13#10 +
          '2)  LAB'#13#10);

    RoomNumber := ReadAndVerify(1, 2, '> ');

    If RoomNumber = 1 Then
        Room := rXeno
    Else
        Room := rLab;

    SelectFirstFloorRoom := Room;
End;

Function SelectSecondFloorRoom(): Rooms;
Var
    Room: Rooms;
    RoomNumber: Integer;
