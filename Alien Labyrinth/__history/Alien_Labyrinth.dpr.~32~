Function ReadAndVerify(Const MIN_NUMBER, MAX_NUMBER: Integer; MyString: String): Integer;

Var
    IsCorrect: Boolean;
    Number: Integer;

Begin
    IsCorrect := True;
    Number := 0;

    Repeat
        Write(MyString);
        IsCorrect := True;

        Try
            ReadLn(Number);
        Except
            WriteLn('Incorrect input, try again.');
            IsCorrect := False;
        End;

        If IsCorrect And ((Number < MIN_NUMBER) Or (Number > MAX_NUMBER)) Then
        Begin
            WriteLn('Введённое число должно попадать в диапазон [', MIN_NUMBER, ',', MAX_NUMBER, '].');
            IsCorrect := False;
        End;

    Until IsCorrect;

    ReadAndVerify := Number;
End;

Function FindPlayerFloor(): Floors;
Var
    ExactFloor: Floors;
    ReadedNumber: Integer;
Begin
    ExactFloor := flFirst;

    WriteLn('Какого цвета стены вокруг Вы наблюдаете?');
    Write(  '1)  Зелёный'#13#10 +
            '2)  Фиолетовый'#13#10 +
            '3)  Белый'#13#10);

    ReadedNumber := ReadAndVerify(1, 3, '> ');

    If ReadedNumber = 1 Then
    Begin
        ExactFloor := flSecond;
        Write(#13#10'Вы находитесь на Втором этаже'#13#10);
    End
    Else
        If ReadedNumber = 2 Then
        Begin
            ExactFloor := flThird;
            Write(#13#10'Вы находитесь на Третьем этаже'#13#10);
        End
        Else
            If ReadedNumber = 3 Then
            Begin
                ExactFloor := flFirst;
                Write(#13#10'Вы находитесь на Первом этаже'#13#10);
            End;

    FindPlayerFloor := ExactFloor;
End;

