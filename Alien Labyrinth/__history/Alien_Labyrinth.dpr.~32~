        rXeno:
            FromXenoToExit();
        rLab:
            FromLabToExit();
        rGlad_ai:
            FromGlad_aiToExit();
        rRelic:
            FromRelicToExit();
        rControlHub:
            FromControlHubToExit();
        rDisco:
            FromDiscoToExit();
    End;

End;

