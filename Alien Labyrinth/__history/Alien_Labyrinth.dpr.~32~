Function SelectFirstFloorRoom(): Rooms;
Var
    Room: Rooms;
    RoomNumber: Integer;
Begin
    RoomNumber := 0;

    WriteLn('В какой комнате вы находитесь?');
    Write('1)  XEN-O'#13#10 +
          '2)  LAB'#13#10);

    RoomNumber := ReadAndVerify(1, 2, '> ');

    If RoomNumber = 1 Then
        Room := rXeno
    Else
        Room := rLab;

    SelectFirstFloorRoom := Room;
End;

