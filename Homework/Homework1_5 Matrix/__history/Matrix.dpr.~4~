Program Matrix;

uses
  System.SysUtils;

Var
    A : Array Of Array Of Integer;
    Sum, SumAll, I, J, Length, Half : Integer;

Begin

    Length := 4;

    If High(A) Mod 2 = 0 Then
        Half := High(A) Div 2
    Else
        Half := (High(A) Div 2) - 1;

    setlength(A, Length);
    setlength(A[0], Length);
    setlength(A[1], Length);
    setlength(A[2], Length);
    setlength(A[3], Length);


    For I := Half To Length Do
    Begin
        For J := 0 To Half Do
        Begin
            Sum := Sum + A[I, J]

        End;

        SumAll := SumAll + Sum;
    End;



End.
