Program Matrix;

uses
  System.SysUtils;

Var
    A : Array [0..4, 0..4] Of Integer;
    SumVer, SumHor, SumAll, I, J, Length, Half : Integer;

Begin

    Length := 5;

    A[0][0] := 0;
    A[0][1] := 7;
    A[0][2] := 2;
    A[0][3] := 1;
    A[0][4] := 4;

    A[1][0] := 3;
    A[1][1] := 2;
    A[1][2] := 1;
    A[1][3] := 0;
    A[1][4] := 1;

    A[2][0] := 1;
    A[2][1] := 9;
    A[2][2] := 8;
    A[2][3] := 5;
    A[2][4] := 1;

    A[3][0] := 1;
    A[3][1] := 2;
    A[3][2] := 7;
    A[3][3] := 4;
    A[3][4] := 2;

    A[4][0] := 3;
    A[4][1] := 5;
    A[4][2] := 5;
    A[4][3] := 2;
    A[4][4] := 2;

    If High(A) Mod 2 = 0 Then
        Half := High(A) Div 2
    Else
        Half := (High(A) Div 2) - 1;

    setlength(A, Length);
    setlength(A[0], Length);
    setlength(A[1], Length);
    setlength(A[2], Length);
    setlength(A[3], Length);


    For I := Half To Length Do
    Begin
        SumVer := 0;
        SumHor := 0;

        For J := 0 To Half Do
        Begin
            SumVer := SumVer + A[J, I];
            SumHor := SumHor + A[I, J];
        End;

        SumAll := SumAll + SumVer + SumHor;
    End;

    If High(A) Mod 2 = 0 Then
        SumAll := SumAll - A[Half, Half];

    WriteLn(SumAll);


    ReadLn;
End.
