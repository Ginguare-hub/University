program Project1;

uses
  System.SysUtils;

Var
    A, B, C, X1, X2: Double;

begin
    A := 1.0;
    B := 1.0;
    C := 1.0;
    X1 := 1.0;
    X2 := 1.0;

    ReadLn(A, B, C);

    If (B*B - 4*A*C > 0) Then
    Begin
    X1 := (-1*B + sqrt(B*B - 4*A*C))/(2*A);
    X2 := (-1*B - sqrt(B*B - 4*A*C))/(2*A);
    FormatFloat('0.00',X1);
    FormatFloat('0.00',X2);
    WriteLn('X1 = ',X1, ', X2 = ',X2)
    End
    Else If (B*B - 4*A*C = 0) Then
    Begin
        X1 := (-1*B + sqrt(B*B - 4*A*C))/(2*A);
        FormatFloat('0.00',X1);
        WriteLn('X1 = X2 = ',X1);
    End
    Else
        WriteLn('Действительных корней нет');

    ReadLn;
end.
