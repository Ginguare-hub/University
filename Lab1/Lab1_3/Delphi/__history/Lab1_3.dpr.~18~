var
  x, x_prev: Real;
  epsilon: Real;
  iteration: Integer;

function phi(x: Real): Real;
begin
  phi := (ln(7.622 * x) + 5) / 8.59;
end;

begin
  x := 0.7; { Начальное приближение }
  epsilon := 0.0001; { Точность }
  iteration := 0;

  repeat
    x_prev := x;
    x := phi(x_prev);
    iteration := iteration + 1;
    Writeln('Iteration ', iteration, ': x = ', x:0:6);
  until Abs(x - x_prev) < epsilon;

  Writeln('Root: x = ', x:0:6);
  Writeln('Number of iterations: ', iteration);
  ReadLn;
end.
