Program ArrayOfNumbers;

Uses
    System.SysUtils;

Var
    A: Array Of Double;
    B: Array Of Double;
    Lenght: Integer;
    I: Integer;
    N: Double;

Const
    MAX_NUMBER: Double = 1024.0;
    MIN_NUMBER: Double = -1024.0;
    MAX_LENGHT: Integer = 10;
    MIN_LENGHT: Integer = 1;

Begin

    Lenght := 1;
    I := 0;
    N := 1.0;

    Repeat
        Try
            Write('Введите число элементов массива A: ');
            ReadLn(Lenght);
            If (Lenght < MIN_LENGHT) Or (Lenght > MAX_LENGHT) Then
                WriteLn('Число элементов массива должно лежать в диапазоне [', MIN_LENGHT, ';', MAX_LENGHT, '], попробуйте ещё раз.');
        Except
            WriteLn('Ошибка ввода, повторите попытку.');
        End;
    Until (Lenght > (MIN_LENGHT - 1)) AND (Lenght < (MAX_LENGHT + 1));

    SetLength(A, Lenght);
    SetLength(B, Lenght);

    For I := 0 To (Lenght - 1) Do
    Begin
        Write('Введите N', I + 1, ' элемент массива: ');
        ReadLn(N);
        A[I] := N;
    End;

    For I := 0 To (Lenght - 1) Do
    Begin
        B[I] := 2 * A[I] + I + 1;
    End;

    For I := 0 To (Lenght - 1) Do
        WriteLn('B[', I, '] = ', B[I]:4:4);

    ReadLn;

End.
