Function ExtractInteger(InputStr: String): String;

Var
    I, J: Integer;
    Answer: String;
    IsNotFound: Boolean;

Begin
    I := Low(InputStr);
    J := 0;
    Answer := '';
    IsNotFound := True;

    While (I < Length(InputStr)) And (IsNotFound) Do
    Begin
        //HasSign := False;
        //HasDigit := False;
        //StartPos := 0;
        //EndPos := 0;

        If ((InputStr[I] = '+') Or (InputStr[I] = '-')) And (IsDigit(InputStr[I + 1])) Then
        Begin
            //HasSign := True;
            //StartPos := I;
            Answer := Answer + InputStr[I];
            J := I + 1;

            While (J < Length(InputStr)) And (IsNotFound) Do
            Begin
                //CurrentChar := InputStr[I];

                If IsDigit(InputStr[J]) Then
                    Answer := Answer + InputStr[J];

                If (J + 1 = Length(InputStr)) And IsDigit(InputStr[J + 1]) Then
                        Answer := Answer + InputStr[J];

                If Not IsDigit(InputStr[J + 1]) Then
                    IsNotFound := false;

                Inc(J);
            End;

        End;

        Inc(I);
    End;

//    If Found Then
//    Begin
//        For J := StartPos To EndPos Do
//            Answer := Answer + InputStr[J];
//    End;

    ExtractInteger := Answer;
End;

Function ReadStringFromFile(Var InputFile: TextFile): String;

Var
    InputStr: String;
    CanReadData: Boolean;

Begin
    InputStr := '';
    CanReadData := True;

    Try
        Reset(InputFile);

        If Not EOF(InputFile) Then
            ReadLn(InputFile, InputStr)
        Else
        Begin
            WriteLn('Error, file is empty.');
            InputStr := '';
            CanReadData := False;
        End;
    Except
        WriteLn('Error reading from file.');
        InputStr := '';
        CanReadData := False;
    End;

    CloseFile(InputFile);

    ReadStringFromFile := InputStr;
End;

Function ReadStringFromConsole(): String;

Var
    InputStr: String;

Begin
    InputStr := '';
    Write('Enter string: ');
    ReadLn(InputStr);
    ReadStringFromConsole := InputStr;
End;

Procedure WriteResultIntoFile(Var OutputFile: TextFile; Answer: String);

Var
    IsReady: Boolean;

Begin
    IsReady := True;

    Try
        Rewrite(OutputFile);
    Except
        IsReady := False;
    End;

    If IsReady Then
    Begin
        If Answer <> '' Then
            WriteLn(OutputFile, 'Extracted integer: ', Answer)
        Else
            WriteLn(OutputFile, 'No valid integer found.');
    End
    Else
        WriteLn('The unexpected error is found.');

    CloseFile(OutputFile);
End;

Procedure WriteResultIntoConsole(Answer: String);

Begin
    If Answer <> '' Then
        WriteLn('Extracted integer: ', Answer)
    Else
        WriteLn('No valid integer found.');
End;

Procedure ReadingStage(Var InputStr: String);

Var
    MyFile: TextFile;
    IsFromFile: Boolean;
    IsOutput: Boolean;
    IsAllDone: Boolean;

Begin
    IsOutput := False;
    IsAllDone := True;
    IsFromFile := False;
    IsFromFile := WorkWithConsoleOrFile(IsOutput);

    If IsFromFile Then
        Repeat
            IsAllDone := True;
            AssignMyFile(MyFile, IsOutput);
            InputStr := ReadStringFromFile(MyFile);

            If InputStr = '' Then
            Begin
                WriteLn('Something went wrong, try again.');
                IsAllDone := False;
            End;
        Until IsAllDone
    Else
        InputStr := ReadStringFromConsole();
End;

Procedure WritingStage(Answer: String);

Var
    MyFile: TextFile;
    IsToFile: Boolean;
    IsOutput: Boolean;

Begin
    IsOutput := True;
    IsToFile := False;

    IsToFile := WorkWithConsoleOrFile(IsOutput);

    If IsToFile Then
    Begin
        AssignMyFile(MyFile, IsOutput);
        WriteResultIntoFile(MyFile, Answer);
    End
    Else
        WriteResultIntoConsole(Answer);
End;

Var
    InputStr, Answer: String;

Begin
    WritePurpose;
    ReadingStage(InputStr);
    Answer := ExtractInteger(InputStr);
    WritingStage(Answer);
    ReadLn;
End.
