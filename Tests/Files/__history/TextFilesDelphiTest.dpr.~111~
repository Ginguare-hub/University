Function ReadAndVerify(Const MIN_NUMBER: Integer; Const MAX_NUMBER: Integer; MyString: String): Integer;

Var
    IsCorrect: Boolean;
    Number: Integer;

Begin

    Number := 0;
    IsCorrect := True;

    Repeat

        Write(MyString);
        IsCorrect := True;

        Try
            ReadLn(Number);
        Except
            WriteLn('Incorrect input, try again.');
            IsCorrect := False;
        End;

        If IsCorrect And ((Number < MIN_NUMBER) Or (Number > MAX_NUMBER)) Then
        Begin
            WriteLn('The number must fit the range [', MIN_NUMBER, ',', MAX_NUMBER, '].');
            IsCorrect := False;
        End;

    Until IsCorrect;

    ReadAndVerify := Number;
End;

Function IsFileText(FilePath: String): Boolean;

Var
    FileExt: String;
    IsText: Boolean;

Begin

    FileExt := ExtractFileExt(FilePath);

    If FileExt = '.txt' Then
        IsText := True
    Else
        IsText := False;

    IsFileText := IsText;

End;

