Function GetPrimeNumber(InputNum: Integer): Integer;
Begin

    Var
        I, J, Counter: Integer;
    Var
        IsShouldStop, IsMustStop: Boolean;

    J := 2;
    Counter := 0;

    IsMustStop := False;
    IsShouldStop := False;

    I := 2;

    If InputNum = 1 Then
        GetPrimeNumber := 2
    Else
    If InputNum = 2 Then
        GetPrimeNumber := 3
    Else
    Begin

        While (Not IsMustStop) Do
        Begin

            IsShouldStop := False;

            For J := 2 To (I - 1) Do
            Begin

                If (I Mod J = 0) And (Not IsShouldStop) Then
                Begin
                    IsShouldStop := True;
                End
                Else
                    If (Not IsShouldStop) Then
                        IsShouldStop := False;

            End;

            If Not IsShouldStop Then
                Counter := Counter + 1;

            If Counter = InputNum Then
            Begin
                IsMustStop := True;
                GetPrimeNumber := I;
            End;

            I := I + 1;

        End;
    End;
End;

