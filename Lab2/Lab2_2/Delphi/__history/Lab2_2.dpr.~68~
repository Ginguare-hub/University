Program Lab2_2;

Uses
    System.SysUtils;

Function GetPrimeNumber(InputNum: Integer): Integer;
Begin

    Var
        Number, J, Counter: Integer;
    Var
        IsShouldStop, IsMustStop: Boolean;

    J := 2;
    Counter := 0;

    IsMustStop := False;
    IsShouldStop := False;

    Number := 2;

    If InputNum = 1 Then
        GetPrimeNumber := 2
    Else
        If InputNum = 2 Then
            GetPrimeNumber := 3
        Else
        Begin

            While (Not IsMustStop) Do
            Begin

                IsShouldStop := False;

                For J := 2 To (Number - 1) Do
                Begin

                    If (Number Mod J = 0) And (Not IsShouldStop) Then
                    Begin
                        IsShouldStop := True;
                    End
                    Else
                        If (Not IsShouldStop) Then
                            IsShouldStop := False;

                End;

                If Not IsShouldStop Then
                    Counter := Counter + 1;

                If Counter = InputNum Then
                Begin
                    IsMustStop := True;
                    GetPrimeNumber := Number;
                End;

                Number := Number + 1;

            End;
        End;
End;

Function DiscoverIsNumberPrime(Number: Integer): Boolean;
Begin
    Var
        I: Integer;
    Var
        IsShouldStop: Boolean;

    IsShouldStop := False;
    DiscoverIsNumberPrime := False;

    For I := 2 To (Number - 1) Do
    Begin
        If (Number Mod I = 0) And (Not IsShouldStop) Then
        Begin
            DiscoverIsNumberPrime := False;
            IsShouldStop := True;
        End
        Else
            If Not IsShouldStop Then
                DiscoverIsNumberPrime := True;
    End;

    If Number = 2 Then
        DiscoverIsNumberPrime := True;

End;

Procedure GetMersenneNumbers(N: Integer);
Begin

    Var
        I, J, Answer, MersenneNumber: Integer;

    I := 1;
    Answer := 3;
    MersenneNumber := 2;

    While Answer < N Do
    Begin
        MersenneNumber := 2;

        For J := 2 To GetPrimeNumber(I) Do
            MersenneNumber := MersenneNumber * 2;

        MersenneNumber := MersenneNumber - 1;
        Answer := MersenneNumber;

        If (DiscoverIsNumberPrime(Answer) = True) And (Answer < N) Then
            WriteLn(Answer);

        I := I + 1;
    End;
End;

Var
    N, I, S: Integer;
    IsCorrect: Boolean;

Begin
    GetMersenneNumbers(524288);

    ReadLn;
End.
