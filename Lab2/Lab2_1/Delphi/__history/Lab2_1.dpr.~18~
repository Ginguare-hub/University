Program Lab2_1;

Uses
    System.SysUtils;

Type
    TArr = Real;

Var
    Arr: Array Of TArr;
    Length, I, Answer: Integer;
    Num, MinDiff, SumOfNums, AbsNum: TArr;

Begin

    //Initialization
    SumOfNums := 0;

    //Проверку ввода и ввод Length
    ReadLn(Length);

    setlength(Arr, Length);

    For I:= 0 To High(Arr) Do
    Begin
        //Проверку ввода
        Write('Element ', I + 1, ' = ');
        ReadLn(Num);
        Arr[I] := Num;
        SumOfNums := SumOfNums + Num;
    End;

    MinDiff := Arr[0];

    For I:= 1 To High(Arr) Do
    Begin

        AbsNum := Abs(Arr[I] - Arr[I - 1]);

        If MinDiff > AbsNum Then
        Begin
            MinDiff := AbsNum;

        End;

    End;

    WriteLn(MinDiff:7:4);




    ReadLn;
End.
