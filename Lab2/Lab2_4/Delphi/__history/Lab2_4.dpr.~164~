Function BinaryToHexadecimal(BNumber: Int64): TArrayOC;

Const
    HNumber: Integer = 10000;

Var
    Counter, Tetrade, ALength, I: Int64;
    AnswerArray: TArrayOC;

Begin

    //ПРОВЕРКА БИНАРНОЕ ЛИ ЧИСЛО

    //РАБОТА С ОТРИЦАТЕЛЬНЫМИ ЧИСЛАМИ

    //БОЛЬШИЕ ЧИСЛА

    ALength := 0;

    ALength := GetNumberOfDigits(BNumber) Div 4;

    If (GetNumberOfDigits(BNumber) Mod 4) > 0 Then
        ALength := ALength + 1;

    Counter := 0;

    SetLength(AnswerArray, ALength);

    If BNumber <> 0 Then
    Begin
        While BNumber <> 0 Do
        Begin

            Tetrade := BNumber Mod HNumber;
            BNumber := BNumber Div HNumber;
            AnswerArray[Counter] := TetradeToHexidecimal(Tetrade);

            Counter := Counter + 1;
        End;
    End
    Else
        If BNumber = 0 Then
            AnswerArray[Counter] := TetradeToHexidecimal(0);

    BinaryToHexadecimal := AnswerArray;
End;

Function OctalToBinary(ONumber: Int64): Int64;  //Проверку не содержит ли число цифры больше 7. Проверку на не слишком ли большое число

Var
    Digit, Index, N, Answer: Int64;
    TransformArray: TArrayOI;


Begin
    Digit := 0;
    Answer := 0;
    Index := 0;
    N := 1;

    SetLength(TransformArray, 8);

    TransformArray := [0, 1, 10, 11, 100, 101, 110, 111];

    While ONumber <> 0 Do
    Begin
        Digit := ONumber Mod 10;
        ONumber := ONumber Div 10;
        Answer := Answer + N * TransformArray[Digit];
        N := N * 1000;
    End;

    OctalToBinary := Answer;
End;

Function DecimalToBinary(DNumber: Int64): Int64;

Const
    BASE: Integer = 2;

Var
    ReverseAnswerArray: TArrayOI;
    NumberOfDigits, I, Answer: Integer;

Begin
    NumberOfDigits := 0;
    I := 0;
    Answer := 0;

    SetLength(ReverseAnswerArray, 64);

    While DNumber <> 0 Do
    Begin
        ReverseAnswerArray[I] := DNumber Mod BASE;
        DNumber := DNumber Div BASE;
        Inc(I);
    End;

    For I := High(ReverseAnswerArray) DownTo Low(ReverseAnswerArray) Do
        Answer := Answer * 10 + ReverseAnswerArray[I];

    DecimalToBinary := Answer;
End;

