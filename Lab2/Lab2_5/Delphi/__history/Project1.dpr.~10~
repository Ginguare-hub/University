Program Project1;

Uses
    System.SysUtils;

Type
    TArrayOI = Array Of Integer;

Function ReadAndVerify(Const MIN_NUMBER, MAX_NUMBER: Integer; MyString: String): Integer;

Var
    IsCorrect: Boolean;
    Number: Integer;

Begin

    Number := 0;
    IsCorrect := True;

    Repeat

        Write(MyString);
        IsCorrect := True;

        Try
            ReadLn(Number);
        Except
            WriteLn('Incorrect input, try again.');
            IsCorrect := False;
        End;

        If IsCorrect And ((Number < MIN_NUMBER) Or (Number > MAX_NUMBER)) Then
        Begin
            WriteLn('The number must fit the range [', MIN_NUMBER, ',', MAX_NUMBER, '].');
            IsCorrect := False;
        End;

    Until IsCorrect;

    ReadAndVerify := Number;
End;

Function ReadArray: TArrayOI;

Var
    MyArray: TArrayOI;
    I, ArrLength: Integer;

Begin

    WriteLn('Write length of array: >');
    ReadArray := MyArray;
End;

Begin

    ReadArray;


    Read;
End.
