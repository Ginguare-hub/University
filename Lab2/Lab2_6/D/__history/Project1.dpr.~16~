Function SumOfProperDivisors(Number: Integer): Integer;

Var
    I, SumOfDivisors, NumberDivTwo: Integer;

Begin
    I := 0;
    SumOfDivisors := 0;
    NumberDivTwo := Number Div 2;

    For I := 1 To NumberDivTwo Do
        If Number Mod I = 0 Then
            SumOfDivisors := SumOfDivisors + I;

    SumOfProperDivisors := SumOfDivisors;
End;

